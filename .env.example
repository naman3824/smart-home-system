# ─────────────────────────────────────────────────────────────────
# Smart Home Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# The dashboard works without any of these — they enable optional
# real-sensor / cloud / alert features.
# ─────────────────────────────────────────────────────────────────

# ── OpenWeather API (for real temperature & humidity) ─────────────
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Twilio WhatsApp alerts (for real SMS/WhatsApp on smoke/intruder) ─
# Get credentials at https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Alias names used by some modules
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token_here
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=whatsapp:+91XXXXXXXXXX

# ── Blynk IoT (for climate-control module) ───────────────────────
# Get a token from https://blynk.io
BLYNK_AUTH_TOKEN=your_blynk_auth_token_here

# ── MQTT Broker (for smoke/gas hardware sensors) ─────────────────
MQTT_BROKER=broker.hivemq.com
MQTT_USER=your_mqtt_username
MQTT_PASS=your_mqtt_password

# ── Firebase (for AQI cloud sync) ────────────────────────────────
FIREBASE_URL=https://your-project.firebaseio.com

# ── Groq API (for AQI chatbot) ───────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Detector tuning (optional overrides) ─────────────────────────
ALERT_DEBOUNCE_SECONDS=300
FALSE_ALARM_CONSECUTIVE=3
READ_INTERVAL_SECONDS=2
